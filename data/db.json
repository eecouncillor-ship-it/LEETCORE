    {
      "id": "c80aa316-1f98-4e0d-a20e-5c8cb7543f1a",
      "title": "Big O of Binary Search",
      "slug": "big-o-of-binary-search",
      "difficulty": "Easy",
      "category": "Algorithms",
      "description": "When binary search is performed on a sorted array of n elements, what is the time complexity in the worst case?",
      "options": [
        {
          "id": "A",
          "text": "O(n)"
        },
        {
          "id": "B",
          "text": "O(log n)"
        },
        {
          "id": "C",
          "text": "O(n log n)"
        },
        {
          "id": "D",
          "text": "O(1)"
        }
      ],
      "correctOptionId": "B",
      "solutionExplanation": "Binary search halves the search space after each comparison, so the number of steps grows logarithmically with input size.",
      "constraints": [
        "The array is already sorted.",
        "Only one value is being searched at a time."
      ],
      "tags": [
        "algorithms",
        "complexity",
        "binary-search"
      ],
      "published": true,
      "createdAt": "2026-04-22T23:19:31.501Z",
      "createdBy": "bd80fe62-f048-4d03-95a9-5424568a1e49"
    },
    {
      "id": "a899d8f8-00fe-4a48-ac77-c39ed8f5a2e3",
      "title": "SQL Clause for Filtering Groups",
      "slug": "sql-clause-for-filtering-groups",
      "difficulty": "Medium",
      "category": "Databases",
      "description": "A query uses GROUP BY and should return only those groups whose count is greater than 3. Which SQL clause should be used for that condition?",
      "options": [
        {
          "id": "A",
          "text": "WHERE"
        },
        {
          "id": "B",
          "text": "ORDER BY"
        },
        {
          "id": "C",
          "text": "HAVING"
        },
        {
          "id": "D",
          "text": "LIMIT"
        }
      ],
      "correctOptionId": "C",
      "solutionExplanation": "HAVING filters grouped rows after aggregation. WHERE filters raw rows before GROUP BY is applied.",
      "constraints": [
        "Assume standard SQL syntax.",
        "The condition is applied after grouping."
      ],
      "tags": [
        "sql",
        "group-by",
        "having"
      ],
      "published": true,
      "createdAt": "2026-04-22T23:19:31.501Z",
      "createdBy": "bd80fe62-f048-4d03-95a9-5424568a1e49"
    },
    {
      "id": "f000cb7f-1a95-42b1-81ec-1fce8149c36f",
      "title": "HTTP Status for Missing Resource",
      "slug": "http-status-for-missing-resource",
      "difficulty": "Easy",
      "category": "Web",
      "description": "A browser requests a route that does not exist on the server. Which HTTP status code is the most appropriate response?",
      "options": [
        {
          "id": "A",
          "text": "200 OK"
        },
        {
          "id": "B",
          "text": "301 Moved Permanently"
        },
        {
          "id": "C",
          "text": "404 Not Found"
        },
        {
          "id": "D",
          "text": "500 Internal Server Error"
        }
      ],
      "correctOptionId": "C",
      "solutionExplanation": "404 Not Found is returned when the requested resource does not exist. A 500 would imply the server crashed while handling a valid request.",
      "constraints": [
        "The resource truly does not exist.",
        "No redirect is configured for the requested route."
      ],
      "tags": [
        "http",
        "web",
        "backend"
      ],
      "published": true,
      "createdAt": "2026-04-22T23:19:31.501Z",
      "createdBy": "bd80fe62-f048-4d03-95a9-5424568a1e49"
    }
